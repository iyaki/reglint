{
	"$schema": "https://opencode.ai/config.json",
	"model": "github-copilot/gpt-5.2-codex",
	"small_model": "github-copilot/gpt-5-mini",
	"mcp": {
		"tech-docs": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"enabled": true
		},
		"code-tools": {
			"type": "local",
			"command": [
				"uvx", "--from", "git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server",
				"--project-from-cwd",
				"--open-web-dashboard", "false",
				"--context", "ide"
			],
			"enabled": false
		},
		"web-search": {
			"type": "local",
			"command": [
				"npx", "-y", "open-websearch@latest"
			],
			"environment": {
				"MODE": "stdio",
				"DEFAULT_SEARCH_ENGINE": "duckduckgo"
			},
			"enabled": true
		},
		"code-examples": {
			"type": "remote",
			"url": "https://mcp.grep.app",
			"enabled": true
		},
		"github": {
			"type": "remote",
			"url": "https://api.githubcopilot.com/mcp/",
			"enabled": false
		},
		"repository-context": {
			"type": "remote",
			"url": "https://gitmcp.io/docs",
			"enabled": true
		},
		"async-bash": {
				"type": "local",
				"command": ["uvx", "async-bash-mcp"],
				"enabled": false
		}
  },
	"plugin": [
		"envsitter-guard@latest",
		"@slkiser/opencode-quota"
	],
	// "experimental": {
	// 	"quotaToast": {
	// 		"enabledProviders": [
	// 			"copilot",
	// 		]
	// 	}
	// }
}
